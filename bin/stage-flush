#!/usr/bin/env php
<?php
/**
 * stage-flush — force-flush all staged .meta files and commit the changelog.
 *
 * Usage:
 *   bin/stage-flush <path/to/config.php>
 */

if ($argc < 2) {
    fwrite(STDERR, "Usage: stage-flush <path/to/config.php>\n");
    exit(1);
}

if (in_array($argv[1], ['-h', '--help'])) {
    echo "Usage: stage-flush <path/to/config.php>\n\n";
    echo "  Flushes staged .meta files, commits untracked .md files,\n";
    echo "  purges expired tombstones, and commits the changelog to git.\n";
    exit(0);
}

$configPath = $argv[1];

if (!file_exists($configPath)) {
    fwrite(STDERR, "Config not found: {$configPath}\n");
    exit(1);
}

require_once $configPath;

if (!defined('DATA_ROOT')) {
    fwrite(STDERR, "Config did not define DATA_ROOT\n");
    exit(1);
}

$storage = storage();

echo "Data root: " . DATA_ROOT . "\n";
echo "Backend:   " . get_class($storage) . "\n";

$before = $storage->changelogCurrentRev();
echo "Changelog rev before: {$before}\n";

$storage->housekeeping('sync');

$after = $storage->changelogCurrentRev();
echo "Changelog rev after:  {$after}\n";

$notesDir = rtrim(DATA_ROOT, '/') . '/notes/';
$metaCount = 0;
if (is_dir($notesDir)) {
    $it = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($notesDir, RecursiveDirectoryIterator::SKIP_DOTS)
    );
    foreach ($it as $f) {
        if ($f->getExtension() === 'meta') $metaCount++;
    }
}
echo "Staged .meta files remaining: {$metaCount}\n";
echo "Done.\n";
