  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "jsdom": "^25.0.0",
    "fake-indexeddb": "^6.0.0",
    "vitest": "^3.1.0"
  }
}
